{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Enchantmen Creator",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/target/debug/enchantmen-creator.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "gdb.exe",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "cargo build"
        }
    ]
}
